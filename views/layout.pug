doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(http-equiv="X-UA-Compatible", content="IE=edge")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        link(rel='stylesheet', href='/dist/style.css')
        title ka4andev
    body
        //- pre= h.dump(user)
        header.header
            ul.menu
                a(href="/") 
                    li.menu-item(data-label="") Main 
                a(href="/blog") 
                    li.menu-item(data-label="blog") Blog 
                if user
                    a(href="/profile") 
                        li.menu-item(data-label="profile") #{user.name}
                else
                    a(href="/login") 
                        li.menu-item(data-label="login") Login
        block messages
            if success_msg
                p #{success_msg}
        .content
            block main
        //- if user
        //-     .username #{user.name}


        block scripts
            script(src="/dist/App.bundle.js")